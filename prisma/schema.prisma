// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IntegrationProvider {
  HEVY
  HEALTH_AUTO_EXPORT
  NUTRITION_MANUAL
  APPLE_HEALTH
}

enum SyncStatus {
  SUCCESS
  FAILURE
  IN_PROGRESS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  belt      String?  @default("White")
  weight    Float?   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  password    String?
  
  // Targets & Settings
  caloriesTarget Float @default(2500)
  proteinTarget  Float @default(160)
  carbsTarget    Float @default(300)
  fatTarget      Float @default(70)
  weeklyLoadTarget Float @default(1000)
  sleepTarget    Float @default(8) // hours
  
  sessions     BjjSession[]
  strengthWorkouts StrengthWorkout[] 
  hevyWorkouts    HevyWorkout[]     
  healthMetrics   HealthMetric[]    
  nutritionLogs   NutritionDaily[]  
  derivedMetrics  DerivedMetric[]
  weightEntries   WeightEntry[]
  integrationConnections IntegrationConnection[]
  profile         UserProfile?
  integrationSecrets IntegrationSecret[]
  rawEvents       RawEvent[]
  syncRuns        SyncRun[]
  exerciseMappings ExerciseMapping[]
  
  // Internal Training Source of Truth
  trainingPrograms TrainingProgram[]
  hevyProgramLinks HevyProgramLink[]
}

model UserProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName           String?
  birthDate             DateTime?
  sex                   String?
  heightCm              Float?
  currentWeightKg       Float?
  targetCategory        String?
  beltRank              String?
  academyTeam           String?
  primaryGoal           String?
  injuriesRestrictions  String?
  timezone              String   @default("America/Bahia")
  unitSystem            String   @default("metric")
  dailyCalorieTarget    Float?
  proteinTargetG        Float?
  carbsTargetG          Float?
  fatTargetG            Float?
  hydrationTargetLiters Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// --- INTEGRATION PERSISTENCE ---

model IntegrationConnection {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  provider        IntegrationProvider
  status          String             @default("DISCONNECTED") 
  apiKey          String?            // API Key reference
  externalUserId  String?            
  lastSyncedAt    DateTime?
  lastError       String?
  credentials     Json?              
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  syncRuns        SyncRun[]

  @@unique([userId, provider])
}

model IntegrationSecret {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       IntegrationProvider
  key            String
  encryptedValue String
  valueHash      String?
  last4          String?
  metadataJson   Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([userId, provider, key])
}

model SyncRun {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id])
  connectionId      String
  connection        IntegrationConnection @relation(fields: [connectionId], references: [id])
  provider          IntegrationProvider
  syncType          String                @default("WORKOUTS") // "WORKOUTS", "PROGRAM_SYNC"
  status            SyncStatus
  startedAt         DateTime              @default(now())
  finishedAt        DateTime?
  recordsProcessed  Int                   @default(0)
  recordsCreated    Int                   @default(0)
  recordsUpdated    Int                   @default(0)
  errorMessage      String?
  metadataJson      Json?
}

model RawEvent {
  id                String             @id @default(cuid())
  userId            String?
  user              User?              @relation(fields: [userId], references: [id])
  provider          IntegrationProvider
  eventType         String?
  externalEventId   String?
  payloadJson       Json
  status            String             @default("PENDING")
  errorMessage      String?
  receivedAt        DateTime           @default(now())
  processedAt       DateTime?
}

// --- HEVY GRANULAR LOGS ---

model HevyWorkout {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  externalWorkoutId String   @unique 
  title             String?
  startedAt         DateTime
  endedAt           DateTime?
  durationSeconds   Int?
  source            String   @default("Hevy")
  rawPayloadJson    Json?
  exercises         HevyExercise[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HevyExercise {
  id                  String      @id @default(cuid())
  workoutId           String
  workout             HevyWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  externalExerciseId  String?     
  exerciseTemplateId  String?     
  exerciseName        String
  orderIndex          Int
  sets                HevySet[]
  rawPayloadJson      Json?
}

model HevySet {
  id                String       @id @default(cuid())
  exerciseId        String
  exercise          HevyExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  externalSetId     String?      
  orderIndex        Int
  setType           String       @default("normal") 
  reps              Int?
  weightKg          Float?
  durationSeconds   Int?
  distanceM         Float?
  isWarmup          Boolean      @default(false)
  rawPayloadJson    Json?
}

// --- INTERNAL TRAINING PROGRAM (SOURCE OF TRUTH) ---

model TrainingProgram {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String
  description     String?
  sourceType      String   @default("Internal")
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  externalId      String?  @unique // Hevy Routine Folder ID
  routines        TrainingRoutine[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  hevyProgramLinks HevyProgramLink[]
}

model TrainingRoutine {
  id                  String   @id @default(cuid())
  programId           String
  program             TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  title               String
  orderIndex          Int
  description         String?
  restSecondsDefault  Int      @default(90)
  isActive            Boolean  @default(true)
  externalId          String?  @unique // Hevy Routine ID
  exercises           TrainingExercise[]
}

model TrainingExercise {
  id                      String   @id @default(cuid())
  routineId               String
  routine                 TrainingRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  orderIndex              Int
  internalName            String
  hevyExerciseTemplateId  String?
  movementGroup           String?
  notes                   String?
  isCustom                Boolean  @default(false)
  setTemplates            TrainingSetTemplate[]
}

model TrainingSetTemplate {
  id              String   @id @default(cuid())
  exerciseId      String
  exercise        TrainingExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  orderIndex      Int
  setType         String   @default("normal")
  reps            Int?
  weightKg        Float?
  durationSeconds Int?
  distanceM       Float?
  restSeconds     Int?
}

// --- HEVY CATALOG & MAPPING ---

model HevyExerciseTemplate {
  id                String   @id @default(cuid())
  externalTemplateId String   @unique @map("external_template_id")
  title             String
  rawPayloadJson    Json?    @map("raw_payload_json")
  category          String?
  primaryMuscle     String?  @map("primary_muscle")
  secondaryMuscles  Json?    @map("secondary_muscles") // Array of strings
  equipment         String?
  isCustom          Boolean  @default(false) @map("is_custom")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("hevy_exercise_templates")
}

model ExerciseMapping {
  id                          String             @id @default(cuid())
  userId                      String             @map("user_id")
  user                        User               @relation(fields: [userId], references: [id])
  internalExerciseName        String             @map("internal_exercise_name")
  internalExerciseId          String?            @map("internal_exercise_id")
  provider                    IntegrationProvider @default(HEVY)
  externalExerciseTemplateId  String             @map("external_exercise_template_id")
  externalExerciseTitle       String             @map("external_exercise_title")
  mappingStatus               String             @default("ACTIVE") @map("mapping_status")
  notes                       String?
  createdAt                   DateTime           @default(now()) @map("created_at")
  updatedAt                   DateTime           @updatedAt @map("updated_at")

  @@unique([userId, internalExerciseName, provider])
  @@map("exercise_mappings")
}

model HevyProgramLink {
  id                  String             @id @default(cuid())
  userId              String             @map("user_id")
  user                User               @relation(fields: [userId], references: [id])
  trainingProgramId   String             @map("training_program_id")
  trainingProgram     TrainingProgram    @relation(fields: [trainingProgramId], references: [id])
  hevyFolderId        String?            @map("hevy_folder_id")
  hevyRoutineId       String?            @map("hevy_routine_id")
  localRoutineId      String?            @map("local_routine_id")
  syncStatus          String             @default("PENDING") @map("sync_status")
  lastSyncedAt        DateTime?          @map("last_synced_at")
  lastError           String?            @map("last_error")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("hevy_program_links")
}

model BjjSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  duration    Int      
  type        String   
  rpe         Int      
  load        Int      
  notes       String?
  createdAt   DateTime @default(now())
}

model StrengthWorkout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  title       String?  
  volume      Float    
  rpe         Int?
  notes       String?
  source      String   @default("Manual")
  externalId  String?  @unique 
  createdAt   DateTime @default(now())
}

model HealthMetric {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  date        DateTime
  type        String             // "HRV", "Sleep", "Weight", "Steps", etc.
  value       Float
  unit        String
  source      IntegrationProvider @default(APPLE_HEALTH)
  externalId  String?            // Source event ID
  createdAt   DateTime           @default(now())

  @@index([userId, date, type])
  @@unique([userId, date, type])
}

model NutritionDaily {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime 
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  waterLiters Float    @default(0)
  adherent    Boolean  @default(false)
  source      IntegrationProvider @default(NUTRITION_MANUAL)
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([userId, date])
}

model WeightEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  weight      Float
  bodyFat     Float?
  notes       String?
  source      String   @default("Manual")
  createdAt   DateTime @default(now())
}

model DerivedMetric {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime 
  weeklyLoad  Int      @default(0)
  fatigue     Int      @default(0)
  recovery    Int      @default(0)
  tendency    String?
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}
