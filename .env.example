# Database
# Required at runtime for routes/services that use Prisma.
# Not required during image build after lazy Prisma initialization.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=fittracker
POSTGRES_DB=fittracker
# Leave these blank in Docker deployments so they are derived from POSTGRES_*.
DATABASE_URL=""
DATABASE_URL_SYNC=""
POSTGRES_HOST_PORT=5432
APP_SECRET="change-this-secret-in-production"

# Integrations - Hevy
# Required at runtime for real Hevy sync.
HEVY_API_KEY=""

# App
APP_HOST_PORT=3020
APP_INTERNAL_PORT=3000
PORT=3000
NODE_ENV=production
# Optional public API URL used by direct browser-side calls.
NEXT_PUBLIC_API_BASE_URL=https://api.fit.minutarecore.space
# Internal target used by Next.js to proxy /api/* inside Docker.
API_PROXY_TARGET=http://backend:8000
