# Database
# Required at runtime for routes/services that use Prisma.
# Not required during image build after lazy Prisma initialization.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fit_tracker?schema=public"
POSTGRES_HOST_PORT=5432

# Integrations - Hevy
# Required at runtime for real Hevy sync.
HEVY_API_KEY=""

# App
APP_HOST_PORT=3020
APP_INTERNAL_PORT=3000
PORT=3000
NODE_ENV=production
# Public app URL used by browser-side calls and deploy metadata.
NEXT_PUBLIC_API_URL=http://localhost:3020
