# === Docker Compose ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=fittracker
POSTGRES_DB=fit_tracker

# === Ports (local dev only) ===
APP_HOST_PORT=3020
APP_INTERNAL_PORT=3000
BACKEND_HOST_PORT=8000
DB_HOST_PORT=5432

# === Frontend ===
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
APP_API_BASE_URL_SERVER=http://backend:8000

# === Backend ===
BACKEND_DATABASE_URL=postgresql+asyncpg://postgres:fittracker@db:5432/fit_tracker
API_V1_PREFIX=/api
CORS_ORIGINS=http://127.0.0.1:3020,http://localhost:3020
LOG_LEVEL=INFO

# === Integrations ===
HEVY_API_BASE_URL=https://api.hevyapp.com/v1
HEVY_API_KEY=
HEVY_SYNC_PAGE_SIZE=20
HEALTH_AUTO_EXPORT_SECRET=

# === Scheduler ===
ENABLE_SCHEDULER=false
SCHEDULER_TIMEZONE=America/Bahia
